[app]
# Interface and port where the app will run its webserver.  The default value
# of localhost will only listen to connections from the current machine. To
# listen on all interfaces use '0.0.0.0'. To listen on the default web address
# port, use port 80 (this will require running with elevated permissions).
address = "localhost:9000"

# Multi-tenant isolation (Solomon fork, v7.17.0+).
# When true, every tenant-scoped query filters by user.company_id and a
# CompanyScopeMiddleware enforces that any :id resource belongs to the
# requesting user's company. When false (default), the schema is in place
# but handlers run in dual-mode — no isolation enforcement. Flip to true
# only after smoke-testing a tenant's view.
enforce_company_isolation = false

# Database.
[db]
host = "localhost"
port = 5432
user = "listmonk"
password = "listmonk"

# Ensure that this database has been created in Postgres.
database = "listmonk"

ssl_mode = "disable"
max_open = 25
max_idle = 25
max_lifetime = "300s"

# Optional space separated Postgres DSN params. eg: "application_name=listmonk gssencmode=disable"
params = ""
